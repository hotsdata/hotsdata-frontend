{
  "name": "hotsdata-frontend",
  "version": "2.0.0",
  "description": "Modern HotsData web frontend",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "start": "npm run dev",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check \"src/{api,app,features,pages,styles,test}/**/*.{js,jsx,css,json}\" \"src/components/{common,data}/**/*.{js,jsx}\" \"src/lib/{TimeUtils,PlayerHeroDataTransformer,HeroStatsHelpers,MatchSummaryDataTransformer}.js\" \"docs/**/*.md\" \"*.md\" \"index.html\" \"vite.config.js\" \"eslint.config.js\"",
    "typecheck": "tsc --noEmit"
  },
  "author": "HotsData",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.3",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "sass": "^1.83.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.5.0",
    "express": "^4.22.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.1.1"
  }
}
